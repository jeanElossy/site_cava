# Copiez ce fichier en `.env` et renseignez les valeurs réelles.
# Le fichier `.env` ne doit JAMAIS être commité.

# Connexion MongoDB Atlas
MONGODB_URI=mongodb+srv://UTILISATEUR:MOTDEPASSE@cluster.mongodb.net/cava?retryWrites=true&w=majority

# Secret de signature des jetons d'authentification.
# Générer une valeur aléatoire longue, par exemple :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

JWT_EXPIRES_IN=7d

# Origine autorisée à appeler l'API (le site public).
CORS_ORIGIN=http://localhost:5173

PORT=4000
NODE_ENV=development

# Webhook de reconstruction du site public (Vercel > Settings > Git > Deploy Hooks)
# Laisser vide desactive le bouton Publier de l administration.
VERCEL_DEPLOY_HOOK=

# Stockage des fichiers envoyés depuis l'administration (Cloudinary).
# Sans ces trois variables, le bouton d'envoi affiche une explication
# au lieu d'échouer. Le secret ne quitte jamais le serveur.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------------------------------------------
# ENCAISSEMENT DES DONS (CinetPay)
# ------------------------------------------------------------------
# Compte marchand : https://cinetpay.com > Integrations > Mes cles API
#
# Les trois valeurs vont ensemble : renseignez-les toutes, ou aucune.
# Une configuration a moitie remplie est refusee au demarrage, car
# elle produirait des dons inities mais jamais verifiables.
#
# CINETPAY_SECRET_KEY sert a verifier la signature des notifications
# de paiement. Sans elle, n'importe qui connaissant l'URL du webhook
# pourrait se declarer donateur.
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=

# Adresse publique de l'API : c'est la que le prestataire envoie sa
# notification serveur a serveur. Doit etre en https en production.
PUBLIC_API_URL=https://site-cava.onrender.com

# Adresse publique du site : c'est la que le donateur revient apres
# avoir paye (page /donate/retour).
PUBLIC_SITE_URL=http://localhost:5173
