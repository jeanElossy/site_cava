# Copiez ce fichier en `.env` et renseignez les valeurs réelles.
# Le fichier `.env` ne doit JAMAIS être commité.

# Connexion MongoDB Atlas
MONGODB_URI=mongodb+srv://UTILISATEUR:MOTDEPASSE@cluster.mongodb.net/cava?retryWrites=true&w=majority

# Secret de signature des jetons d'authentification.
# Générer une valeur aléatoire longue, par exemple :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

JWT_EXPIRES_IN=7d

# Origine autorisée à appeler l'API (le site public).
CORS_ORIGIN=http://localhost:5173

PORT=4000
NODE_ENV=development

# Webhook de reconstruction du site public (Vercel > Settings > Git > Deploy Hooks)
# Laisser vide desactive le bouton Publier de l administration.
VERCEL_DEPLOY_HOOK=

# Stockage des fichiers envoyés depuis l'administration (Cloudinary).
# Sans ces trois variables, le bouton d'envoi affiche une explication
# au lieu d'échouer. Le secret ne quitte jamais le serveur.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
